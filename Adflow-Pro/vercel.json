{
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/publish-scheduled",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/expire-ads",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/notify-expiring",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/db-heartbeat",
      "schedule": "*/30 * * * *"
    }
  ]
}
