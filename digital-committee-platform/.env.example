# Environment Variables
# Copy this file to .env and fill in your Supabase credentials

# Supabase Project URL (from Project Settings > API)
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anonymous Key (from Project Settings > API)
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Supabase Service Role Key (NEVER expose on frontend — backend/admin use only)
SERVICE_ROLE_KEY=your-service-role-key-here
