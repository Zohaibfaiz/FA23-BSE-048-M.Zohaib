{
    "$schema":  "https://openapi.vercel.sh/vercel.json",
    "framework":  "vite",
    "installCommand":  "npm --prefix ElectionHub/election-system install",
    "buildCommand":  "npm run build",
    "outputDirectory":  "ElectionHub/election-system/dist",
    "rewrites":  [
                     {
                         "source":  "/(.*)",
                         "destination":  "/index.html"
                     }
                 ]
}
